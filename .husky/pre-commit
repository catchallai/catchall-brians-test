#!/bin/sh

# Only run on local environments
if [ "$CI" = "true" ]; then
  echo "Skipping pre-commit hook in CI environment."
  exit 0
fi

# Early exit if only .husky/pre-commit is staged
# Use ACMR to include renamed files; || true prevents grep from exiting with code 1 on empty input
ONLY_HUSKY_STAGED=$(git diff --cached --name-only --diff-filter=ACMR | grep -v '^$' | grep -v '.husky/pre-commit' || true)
if [ -z "$ONLY_HUSKY_STAGED" ]; then
  echo "Only .husky/pre-commit is staged. Skipping checks."
  exit 0
fi

RED='\033[0;31m'
GREEN='\033[0;32m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color

echo "${CYAN}Running Before Takeoff Checklist ✈️${NC}"

# Get staged files (ACMR includes renamed files)
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.(js|jsx|ts|tsx|css|md|json)$' | grep -vE '(^|/)\\.prettierignore$|(^|/)(node_modules|dist|build)(/|$)|(^|/)\\.env(\..*)?$|(^|/)\\.vscode(/|$)|.*\.log$|.*\.generated\..*|.*\.min\..*' || true)
ESLINT_FILES=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.(js|jsx|ts|tsx)$' || true)
DENO_FILES=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '^base44/functions/.+\.ts$' || true)

echo "Staged files for Prettier: $STAGED_FILES"
echo "Staged files for ESLint: $ESLINT_FILES"
echo "Staged files for Deno typecheck: $DENO_FILES"

# Early exit if nothing to check
if [ -z "$STAGED_FILES" ] && [ -z "$ESLINT_FILES" ] && [ -z "$DENO_FILES" ]; then
  echo "No files to check with Prettier, ESLint, or Deno. Skipping checks."
  exit 0
fi

# Step 1: Prettier
if [ -n "$STAGED_FILES" ]; then
  echo "Step 1: Running Prettier check on staged files..."
  npx prettier --check $STAGED_FILES
  if [ $? -eq 0 ]; then
    echo "${GREEN}Prettier check passed ✅${NC}"
  else
    echo "${RED}Prettier check failed ❌${NC}"
    echo "To bypass checks, use one of:"
    echo "  git commit --no-verify -m 'your message'"
    echo "  HUSKY=0 git commit -m 'your message'"
    exit 1
  fi
else
  echo "No files to check with Prettier. Skipping."
fi

# Step 2: ESLint
if [ -n "$ESLINT_FILES" ]; then
  echo "Step 2: Running ESLint check on staged files..."

  # Temporarily disable exit-on-error
  set +e
  ESLINT_OUTPUT=$(git diff --cached --name-only --diff-filter=ACMR -z \
  | grep -zE '\.(js|jsx|ts|tsx)$' \
  | xargs -0 npx eslint --max-warnings=0 --no-warn-ignored 2>&1)
  ESLINT_EXIT_CODE=$?
  set -e

  if [ $ESLINT_EXIT_CODE -eq 0 ]; then
    echo "${GREEN}ESLint check passed ✅${NC}"
  else
    echo "${RED}ESLint check failed ❌${NC}"

    echo ""
    echo "🔍 ESLint output:"
    echo "----------------------------------------"
    echo "$ESLINT_OUTPUT"
    echo "----------------------------------------"

    echo ""
    echo "💡 Why this failed:"
    echo "- ESLint is run with --max-warnings=0"
    echo "- That means ANY warning will fail the commit"

    if echo "$ESLINT_OUTPUT" | grep -q 'no-unused-vars'; then
      echo "👉 Tip: Prefix unused variables with an underscore (e.g., _myVar)"
    fi

    if echo "$ESLINT_OUTPUT" | grep -q 'File ignored because no matching configuration was supplied'; then
      echo "👉 Tip: ESLint is not configured for this file."
      echo "   - Check your eslint.config.js or .eslintrc"
      echo "   - Make sure this file type/path is included"
    fi

    echo ""
    echo "To bypass checks, use one of:"
    echo "  git commit --no-verify -m 'your message'"
    echo "  HUSKY=0 git commit -m 'your message'"

    exit 1
  fi
else
  echo "No files to check with ESLint. Skipping."
fi

# Step 3: Deno typecheck (backend functions only)
if [ -n "$DENO_FILES" ]; then
  echo "Step 3: Running Deno typecheck on staged backend files..."

  set +e
  DENO_OUTPUT=$(npx deno check --config base44/deno.json $DENO_FILES 2>&1)
  DENO_EXIT_CODE=$?
  set -e

  if [ $DENO_EXIT_CODE -eq 0 ]; then
    echo "${GREEN}Deno typecheck passed ✅${NC}"
  else
    echo "${RED}Deno typecheck failed ❌${NC}"

    echo ""
    echo "🔍 Deno output:"
    echo "----------------------------------------"
    echo "$DENO_OUTPUT"
    echo "----------------------------------------"

    echo ""
    echo "💡 Note: 'deno check' uses base44/deno.json (strict: false). Pre-existing"
    echo "    backend errors live behind 'npm run typecheck:backend' — this hook only"
    echo "    blocks commits that introduce new errors in staged files."
    echo ""
    echo "To bypass checks, use one of:"
    echo "  git commit --no-verify -m 'your message'"
    echo "  HUSKY=0 git commit -m 'your message'"

    exit 1
  fi
else
  echo "No files to check with Deno. Skipping."
fi

echo "${CYAN}Before Takeoff Checklist Complete. Commit Cleared for Takeoff 🛫${NC}"

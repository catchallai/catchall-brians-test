#!/bin/sh

# Only run on local environments
if [ "$CI" = "true" ]; then
  echo "Skipping pre-commit hook in CI environment."
  exit 0
fi

# Allow bypass with --skip-checklist
for arg in "$@"; do
  if [ "$arg" = "--skip-checklist" ]; then
    echo "Bypassing pre-commit checklist via --skip-checklist flag."
    exit 0
  fi
done

# Early exit if only .husky/pre-commit is staged
ONLY_HUSKY_STAGED=$(git diff --cached --name-only --diff-filter=ACM | grep -v '^\.husky/pre-commit$' || true)
if [ -z "$ONLY_HUSKY_STAGED" ]; then
  echo "Only .husky/pre-commit is staged. Skipping checks."
  exit 0
fi

RED='\033[0;31m'
GREEN='\033[0;32m'
NC='\033[0m' # No Color

echo "Running Before Takeoff Checklist ✈️"

# Get staged files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(js|jsx|ts|tsx|css|md|json)$' || true)
ESLINT_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(js|jsx|ts|tsx)$' || true)

echo "Staged files for Prettier: $STAGED_FILES"
echo "Staged files for ESLint: $ESLINT_FILES"

# Early exit if nothing to check
if [ -z "$STAGED_FILES" ] && [ -z "$ESLINT_FILES" ]; then
  echo "No files to check with Prettier or ESLint. Skipping checks."
  exit 0
fi

# Step 1: Prettier
if [ -n "$STAGED_FILES" ]; then
  echo "Step 1: Running Prettier check on staged files..."
  npx prettier --check $STAGED_FILES
  if [ $? -eq 0 ]; then
    echo "${GREEN}Prettier check passed ✅${NC}"
  else
    echo "${RED}Prettier check failed ❌${NC}"
    echo "To bypass checks, use: git commit --skip-checklist -m 'your message'"
    exit 1
  fi
else
  echo "No files to check with Prettier. Skipping."
fi

# Step 2: ESLint
if [ -n "$ESLINT_FILES" ]; then
  echo "Step 2: Running ESLint check on staged files..."
  npx eslint $ESLINT_FILES --max-warnings=0 2>eslint_output.log
  if [ $? -eq 0 ]; then
    echo "${GREEN}ESLint check passed ✅${NC}"
  else
    echo "${RED}ESLint check failed ❌${NC}"
    if grep -q 'no-unused-vars' eslint_output.log; then
      echo "Tip: To ignore unused variables, prefix them with an underscore (e.g., _myVar)."
    fi
    cat eslint_output.log
    rm -f eslint_output.log
    echo "To bypass checks, use: git commit --skip-checklist -m 'your message'"
    exit 1
  fi
else
  echo "No files to check with ESLint. Skipping."
fi

echo "Before Takeoff Checklist Complete ✅. Commit will proceed ✈️."
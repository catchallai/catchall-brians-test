{
  "name": "DataRoomFile",
  "type": "object",
  "properties": {
    "data_room_id": {
      "type": "string",
      "description": "Associated data room ID"
    },
    "project_id": {
      "type": "string",
      "description": "Associated project ID"
    },
    "media_asset_id": {
      "type": "string",
      "description": "Original media asset ID"
    },
    "file_name": {
      "type": "string",
      "description": "File name"
    },
    "file_url": {
      "type": "string",
      "description": "Secure file URL"
    },
    "file_size": {
      "type": "number",
      "description": "File size in bytes"
    },
    "file_type": {
      "type": "string",
      "description": "MIME type or file extension"
    },
    "uploaded_by": {
      "type": "string",
      "description": "Email of who uploaded original file"
    },
    "uploaded_at": {
      "type": "string",
      "format": "date-time",
      "description": "When file was uploaded"
    },
    "is_synced": {
      "type": "boolean",
      "default": true,
      "description": "Whether file is synced from Approved folder"
    },
    "view_count": {
      "type": "number",
      "default": 0,
      "description": "How many times viewed by clients"
    },
    "download_count": {
      "type": "number",
      "default": 0,
      "description": "How many times downloaded by clients"
    }
  },
  "required": ["data_room_id", "file_name", "file_url"]
}